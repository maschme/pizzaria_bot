# Copie para .env e preencha. Opção 1: uma instância = uma empresa = um banco.
# Cada instância usa seu próprio .env (PORT, DB_NAME, PM2_APP_NAME diferentes).

# Porta do servidor HTTP (Ex.: 3007, 3008 para múltiplas instâncias)
PORT=3007

# Nome no PM2 (ex.: pizzaria-loja1, empresa-x). Usado pelo setup.sh / setup.ps1
PM2_APP_NAME=pizzaria-bot

# Banco de dados (um database por empresa, ex.: pizzaria_loja1, pizzaria_loja2)
DB_HOST=vms.cutplay.com.br
DB_PORT=3306
DB_USER=mitouser
DB_PASSWORD=naoteconto
DB_NAME=pizzaria
